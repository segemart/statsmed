# Copy to .env and fill in values. Do not commit .env.
# Example for deployment under /statsmed (e.g. behind reverse proxy):
#   NEXT_PUBLIC_BASE_PATH=/statsmed
#   NEXT_PUBLIC_API_URL=/statsmed/api
# Example for root deployment:
#   NEXT_PUBLIC_BASE_PATH=
#   NEXT_PUBLIC_API_URL=/api

NEXT_PUBLIC_BASE_PATH=
NEXT_PUBLIC_API_URL=
JWT_SECRET=

# Optional: override Postgres credentials (must match DATABASE_URL in backend)
POSTGRES_USER=statsmed
POSTGRES_PASSWORD=statsmed
POSTGRES_DB=statsmed

# CORS: comma-separated list of allowed origins
# For production: CORS_ORIGINS=https://statsmed.segeroth.ai
CORS_ORIGINS=http://localhost:3000

# Set to "production" on server to disable Swagger docs
ENV=development
